# Honeybadger CLI Configuration
# Copy this file to ~/.honeybadger-cli.yaml and update with your settings

# Your Honeybadger API key
api_key: your-api-key-here

# Personal auth token for Data API commands (optional). Prefer `hb auth login`
# to sign in with OAuth instead; a token set here takes precedence.
# auth_token: your-personal-auth-token
